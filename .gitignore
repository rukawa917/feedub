# =============================================================================
# Feedub V2 - Comprehensive .gitignore
# Backend: Python/FastAPI | Frontend: React/TypeScript
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example


# -----------------------------------------------------------------------------
# Python / Backend
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# UV package manager
.uv/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Linters
.ruff_cache/

# Celery
celerybeat-schedule
celerybeat.pid

# SQLite (if used for local testing)
*.db
*.sqlite3

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Scrapy
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# pdm
.pdm.toml
.pdm-python
.pdm-build/

# PEP 582
__pypackages__/

# Alembic (but keep versions directory)
# Note: Don't ignore alembic/versions/ - those are migration files

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
# Dependencies
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz

# Build outputs
dist/
build/
.next/
out/
.nuxt/
.output/
.cache/

# Vite
*.local

# Turbo
.turbo/

# Parcel
.parcel-cache/

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Tailwind
tailwind.config.js.timestamp-*

# Storybook
storybook-static/

# Temporary folders
tmp/
temp/

# -----------------------------------------------------------------------------
# IDE / Editors
# -----------------------------------------------------------------------------
# VSCode (keep settings, ignore local history)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# JetBrains IDEs (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*.swn
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# Zed
.zed/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Logs & Debug
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
debug.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Docker (local only)
# -----------------------------------------------------------------------------
# Don't ignore docker-compose.yml or Dockerfiles
.docker/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Certificates (local dev only)
*.pem
*.key
*.crt
!*.example.pem

# Backup files
*.bak
*.backup
*.old


# Claude Code / AI assistants
.claude/
.sisyphus/
.omc/
